{
  "manifest_version": 3,
  "name": "Flyball Team Finder",
  "description": "Find flyball teams near you. Search by location or use GPS to discover local teams.",
  "version": "1.0.0",
  "permissions": ["geolocation"],
  "host_permissions": [
    "https://app.flyballhub.com/*",
    "https://nominatim.openstreetmap.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
